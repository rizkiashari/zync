# Salin ke .env.local — npm run dev
#
# API di mesin lokal:
# VITE_API_URL=http://localhost:8080
#
# API di VPS (CORS harus mengizinkan origin dev, mis. http://localhost:5173):
VITE_API_URL=http://YOUR_VPS_IP:8080

# Midtrans (opsional)
# VITE_MIDTRANS_CLIENT_KEY=
# VITE_MIDTRANS_IS_PRODUCTION=false
