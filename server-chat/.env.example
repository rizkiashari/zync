# MAINTENANCE_ADMIN_EMAIL=maintenance@zync.local
# MAINTENANCE_ADMIN_PASSWORD=ChangeThisInProduction1!
# MAINTENANCE_ADMIN_USERNAME=MaintenanceAdmin