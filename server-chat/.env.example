# Gunakan file terpisah (disarankan):
#   cp .env.local.example .env.local     → dev / go run / compose lokal
#   cp .env.prod.example .env.prod       → produksi; deploy script mengunggah ini sebagai .env di server
#
# Docker Compose: docker compose --env-file .env.local up -d   (atau .env.prod di VPS)
#
# Tanpa file di atas, fallback ke .env (legacy).
