DATABASE_DSN=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME?timezone=UTC
ADDR=:8080
JWT_SECRET=use-a-long-random-secret
JWT_TTL=72h

LIVEKIT_URL=LIVEKIT_URL
LIVEKIT_API_KEY=LIVEKIT_API_KEY
LIVEKIT_API_SECRET=LIVEKIT_API_SECRET
# SMTP (optional – email notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Zync <no-reply@example.com>

# Midtrans Snap (server key only — never expose in the browser)
# MIDTRANS_SERVER_KEY=SB-Mid-server-...
# MIDTRANS_IS_PRODUCTION=false
# Set Notification URL in Midtrans Dashboard to:
#   https://YOUR-API-HOST/api/payments/midtrans/notification
# (POST). Successful payments auto-approve the matching workspace transaction.

# Web Push / VAPID (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173
