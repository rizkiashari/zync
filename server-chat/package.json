{
  "name": "server-chat",
  "private": true,
  "scripts": {
    "build": "go build -o bin/server ./cmd/server",
    "dev": "air",
    "lint": "go vet ./...",
    "deploy:vps": "bash ../scripts/deploy-server-to-vps.sh",
    "deploy:vps:local-build": "env REMOTE_BUILD=0 bash ../scripts/deploy-server-to-vps.sh",
    "deploy:vps:no-build": "env DEPLOY_NO_BUILD=1 bash ../scripts/deploy-server-to-vps.sh"
  }
}
