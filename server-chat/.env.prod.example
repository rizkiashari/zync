# Salin ke .env.prod — VPS / production. Set GO_ENV=production hanya jika jalan binary di host;
# di Docker biasanya variabel sudah dari compose (tanpa file di dalam container).

DATABASE_DSN=postgresql://USER:PASSWORD@127.0.0.1:5433/DB?sslmode=disable&timezone=UTC
ADDR=:8080
JWT_SECRET=change-me-long-random
JWT_TTL=72h
# Hanya origin http/https yang valid untuk gin-contrib/cors.
# Sertakan URL frontend produksi (PM2 static, mis. :4173) dan dev lokal jika perlu.
ALLOWED_ORIGINS=https://your-frontend.example,http://YOUR_VPS_IP:4173,http://YOUR_VPS_IP:5173,http://localhost,https://localhost

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# MIDTRANS_SERVER_KEY=
# MIDTRANS_IS_PRODUCTION=false

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

POSTGRES_USER=zync_app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=zync
API_PUBLISH_PORT=8080
DOCKER_DATABASE_DSN=postgresql://zync_app:URL_ENCODED_PASSWORD@db:5432/zync?sslmode=disable&timezone=UTC
