# Salin ke .env.local — development / go run + docker compose (--env-file .env.local).
# GO_ENV tidak perlu diset.

# Postgres di Mac/Linux lokal (tanpa Docker): biasanya port 5432.
DATABASE_DSN=postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE_NAME?sslmode=disable&timezone=UTC
ADDR=:8080
JWT_SECRET=use-a-long-random-secret
JWT_TTL=72h
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# MIDTRANS_SERVER_KEY=
# MIDTRANS_IS_PRODUCTION=false

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Docker Compose (kalau DB pakai container; hostname db)
POSTGRES_USER=USER
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DB=DATABASE_NAME
API_PUBLISH_PORT=8080
DOCKER_DATABASE_DSN=postgresql://USER:PASSWORD@db:5432/DATABASE_NAME?sslmode=disable&timezone=UTC
