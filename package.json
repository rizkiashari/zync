{
	"name": "Zync",
	"private": true,
	"packageManager": "npm@10.8.2",
	"workspaces": [
		"client-chat",
		"server-chat"
	],
	"scripts": {
		"dev": "node node_modules/turbo/bin/turbo run dev",
		"build": "node node_modules/turbo/bin/turbo run build",
		"lint": "node node_modules/turbo/bin/turbo run lint",
		"client": "npm run dev -w client-chat",
		"server": "npm run dev -w server-chat",
		"deploy:vps": "npm run deploy:vps -w server-chat",
		"deploy:vps:local-build": "npm run deploy:vps:local-build -w server-chat",
		"deploy:vps:no-build": "npm run deploy:vps:no-build -w server-chat",
		"deploy:web:vps": "bash scripts/deploy-web-to-vps.sh",
		"deploy:vps:all": "bash scripts/deploy-vps-build-all.sh"
	},
	"devDependencies": {
		"turbo": "^2.5.4"
	},
	"dependencies": {
		"@capacitor/app": "^7.1.2",
		"react-is": "^19.2.4"
	}
}
